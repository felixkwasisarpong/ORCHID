# LLM provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override base URLs (useful in Docker)
# If using the bundled Ollama container:
# OLLAMA_BASE_URL=http://ollama:11434
# If Ollama runs on host machine:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=

# Optional: custom provider base URLs
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
