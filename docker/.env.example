# LLM provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override base URLs (useful in Docker)
# If using the bundled Ollama container:
# OLLAMA_BASE_URL=http://ollama:11434
# If Ollama runs on host machine:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=

# Optional: custom provider base URLs
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=

# MCP filesystem server settings (stdio)
MCP_TRANSPORT=stdio
MCP_FS_PATHS=/app
MCP_TOOL_NAME=list_directory
MCP_TOOL_PATH=/app
MCP_STDIO_REUSE_SESSION=false

# Disable CrewAI / OpenTelemetry telemetry to avoid signal handler errors in threads
CREWAI_DISABLE_TELEMETRY=true
CREWAI_DISABLE_TRACKING=true
OTEL_SDK_DISABLED=true
